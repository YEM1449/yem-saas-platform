# ── Required (app will not start without these) ─────────────────────────────

# PostgreSQL JDBC URL (run: docker run -d --name hlm-postgres
#   -e POSTGRES_DB=hlm -e POSTGRES_USER=hlm_user -e POSTGRES_PASSWORD=hlm_pwd
#   -p 5432:5432 postgres:16-alpine)
DB_URL=jdbc:postgresql://localhost:5432/hlm
DB_USER=hlm_user
DB_PASSWORD=hlm_pwd

# JWT signing key — minimum 32 characters (256 bits) for HS256
# Generate a strong key: openssl rand -hex 32
JWT_SECRET=0123456789abcdef0123456789abcdef01234567

# ── Optional / Defaults shown ────────────────────────────────────────────────

JWT_TTL_SECONDS=3600

# SMTP (no-op stubs used if not set)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=no-reply@example.com
EMAIL_PASSWORD=changeme
EMAIL_FROM=noreply@example.com

# Outbox processor
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=3
OUTBOX_POLL_INTERVAL_MS=30000

# Scheduler cron expressions
PAYMENTS_OVERDUE_CRON="0 0 6 * * *"
REMINDER_CRON="0 0 8 * * *"

# Media storage
MEDIA_STORAGE_DIR=./uploads
MEDIA_MAX_FILE_SIZE=10485760

# Portal magic-link base URL (used in email links sent to buyers)
APP_PORTAL_BASE_URL=http://localhost:4200

# CORS (restrict in production)
CORS_ALLOWED_ORIGINS=http://localhost:4200
