# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL JDBC URL.
# Run a local dev DB: docker run -d --name hlm-postgres
#   -e POSTGRES_DB=hlm -e POSTGRES_USER=hlm_user -e POSTGRES_PASSWORD=hlm_pwd
#   -p 5432:5432 postgres:16-alpine
DB_URL=jdbc:postgresql://localhost:5432/hlm
DB_USER=hlm_user
DB_PASSWORD=hlm_pwd

# ── JWT ───────────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing key — minimum 32 characters (256 bits).
# Generate a strong key: openssl rand -base64 32
JWT_SECRET=replace-with-a-random-32-plus-char-string
# CRM access token TTL in seconds (default 1 hour).
JWT_TTL_SECONDS=3600

# ── TLS / HTTPS ───────────────────────────────────────────────────────────────
# Mode A — Embedded Tomcat TLS (dev/staging):
#   1. Generate a self-signed certificate: bash scripts/generate-dev-cert.sh
#   2. Set SSL_ENABLED=true, SERVER_PORT=8443, HTTP_REDIRECT_PORT=8080
#   3. HTTP requests on HTTP_REDIRECT_PORT are redirected to HTTPS.
#
# Mode B — Production behind Nginx (recommended):
#   1. Keep SSL_ENABLED=false (Nginx handles TLS, Spring Boot listens plain HTTP).
#   2. Set FORWARD_HEADERS_STRATEGY=FRAMEWORK so Spring trusts X-Forwarded-Proto.
#   3. See nginx/nginx.conf for the full Nginx configuration.
SSL_ENABLED=false
SERVER_PORT=8080
# Required when SSL_ENABLED=true:
SSL_KEYSTORE_PATH=classpath:ssl/hlm-dev.p12
SSL_KEYSTORE_PASSWORD=changeit
SSL_KEY_ALIAS=hlm-dev
# HTTP redirect port (plain HTTP → HTTPS redirect connector, active when SSL_ENABLED=true)
HTTP_REDIRECT_PORT=8080
# Required for production behind reverse proxy (Nginx/cloud LB):
FORWARD_HEADERS_STRATEGY=NONE

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave EMAIL_HOST blank to use the no-op provider (logs to console — dev default).
# SmtpEmailSender activates automatically when EMAIL_HOST is set.
#
# SendGrid:  EMAIL_HOST=smtp.sendgrid.net  EMAIL_USER=apikey  EMAIL_PORT=587
# Gmail:     EMAIL_HOST=smtp.gmail.com      EMAIL_USER=you@gmail.com  EMAIL_PORT=587
# Mailgun:   EMAIL_HOST=smtp.mailgun.org   EMAIL_USER=postmaster@yourdomain EMAIL_PORT=587
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
# Sender address shown in the From field of all outbound emails.
EMAIL_FROM=noreply@hlm.local

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Leave TWILIO_ACCOUNT_SID blank to use the no-op provider (logs to console — dev default).
# TwilioSmsSender activates automatically when TWILIO_ACCOUNT_SID is set.
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio phone number in E.164 format, e.g. +15551234567
TWILIO_FROM=

# ── Frontend & Portal base URLs ──────────────────────────────────────────────
# FRONTEND_BASE_URL is used in staff invitation email links.
# docker-compose serves the frontend on port 80 (nginx), NOT 4200.
# For ng serve (local dev without Docker): use http://localhost:4200
FRONTEND_BASE_URL=http://localhost

# PORTAL_BASE_URL is prepended to portal magic-link token URLs sent by email.
# MUST start with https:// in any environment handling real user data.
PORTAL_BASE_URL=http://localhost
# Cron expression for the portal token cleanup job (default: daily at 03:00).
PORTAL_CLEANUP_CRON="0 0 3 * * *"

# ── Outbox Processor ─────────────────────────────────────────────────────────
# Number of PENDING messages claimed per scheduler tick (FOR UPDATE SKIP LOCKED).
OUTBOX_BATCH_SIZE=20
# Maximum send attempts before a message is permanently marked FAILED.
OUTBOX_MAX_RETRIES=3
# Delay between scheduler ticks in milliseconds.
OUTBOX_POLL_INTERVAL_MS=5000

# ── Scheduler Crons ──────────────────────────────────────────────────────────
PAYMENTS_OVERDUE_CRON="0 0 6 * * *"
REMINDER_CRON="0 0 8 * * *"

# ── Media Storage (local filesystem — default) ────────────────────────────────
# Directory for property photo uploads.
MEDIA_STORAGE_DIR=./uploads
# Maximum allowed upload size in bytes (default 10 MB).
MEDIA_MAX_FILE_SIZE=10485760

# ── Object Storage (S3-compatible protocol) ─────────────────────────────────────
# Works with any S3-compatible provider. Set MEDIA_OBJECT_STORAGE_ENABLED=true
# and configure the endpoint for your chosen provider.
# Leave MEDIA_OBJECT_STORAGE_ENABLED=false to use local disk storage (dev default).
#
# Provider endpoint examples:
#   OVH Object Storage (Gravelines): https://s3.gra.perf.cloud.ovh.net
#   OVH Object Storage (Strasbourg): https://s3.sbg.perf.cloud.ovh.net
#   Scaleway Object Storage (Paris): https://s3.fr-par.scw.cloud
#   Hetzner Object Storage (FSN1):   https://fsn1.your-objectstorage.com
#   Cloudflare R2:                   https://<accountid>.r2.cloudflarestorage.com
#   MinIO (self-hosted / docker):    http://minio:9000  or  http://localhost:9000
#   AWS S3:                          leave endpoint blank (SDK auto-resolves)
#
MEDIA_OBJECT_STORAGE_ENABLED=false
MEDIA_OBJECT_STORAGE_ENDPOINT=
MEDIA_OBJECT_STORAGE_REGION=eu-west-1
MEDIA_OBJECT_STORAGE_BUCKET=hlm-media
MEDIA_OBJECT_STORAGE_ACCESS_KEY=
MEDIA_OBJECT_STORAGE_SECRET_KEY=
#
# MinIO credentials (only needed when using docker-compose.yml MinIO service)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Redis Distributed Cache ───────────────────────────────────────────────────
# Set REDIS_ENABLED=true to replace in-process Caffeine with Redis.
# Required for multi-instance (horizontal scaling) deployments.
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank for no auth (local dev). MUST be set in production.
REDIS_PASSWORD=

# ── PostgreSQL (Docker Compose) ───────────────────────────────────────────────
# Used by docker-compose.yml to configure the postgres container.
POSTGRES_DB=hlm
POSTGRES_USER=hlm_user
POSTGRES_PASSWORD=hlm_pwd

# ── GDPR / Law 09-08 ─────────────────────────────────────────────────────────
# Days after last interaction before a soft-deleted contact is anonymized (5 years default).
GDPR_RETENTION_DAYS=1825
# Cron expression for the daily GDPR retention sweep (server local time).
DATA_RETENTION_CRON="0 0 2 * * *"

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# OTLP HTTP endpoint for the OTel Collector (or managed backend).
# Leave default for local otel-collector-config.yml setup.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Trace sampling rate: 1.0 = 100%, 0.1 = 10%. Lower in high-traffic production.
OTEL_SAMPLE_RATE=1.0

# ── Docker / CI ───────────────────────────────────────────────────────────────
# Image tag to pull in production (docker-compose.prod.yml).
IMAGE_TAG=latest
# Container registry prefix (without trailing slash).
REGISTRY=ghcr.io/yem1449

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Empty = deny all cross-origin requests.
# In production, set to your exact frontend domain: https://app.yourcompany.com
CORS_ALLOWED_ORIGINS=http://localhost:4200
